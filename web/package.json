{
    "name": "rustzen-admin",
    "version": "0.2.2",
    "private": true,
    "type": "module",
    "scripts": {
        "prepare": "vp config || true",
        "preview": "vp preview",
        "postbuild": "zipper -o dist-rustzen-admin",
        "dev": "vp dev",
        "build": "vp build",
        "build:prod": "tsc --project tsconfig.build.json --noEmit && vite build",
        "lint": "vp lint",
        "fmt": "vp fmt",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@ant-design/icons": "^6.1.0",
        "@ant-design/plots": "^2.6.8",
        "@ant-design/pro-components": "^2.8.10",
        "@emotion/react": "^11.14.0",
        "@tanstack/react-query": "^5.91.0",
        "@tanstack/react-router": "^1.167.5",
        "antd": "^6.3.3",
        "http-proxy-middleware": "^3.0.5",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@rustzen/zipper": "^0.1.4",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/react-router-devtools": "^1.166.9",
        "@tanstack/router-plugin": "^1.166.14",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.5.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitejs/plugin-react": "^6.0.1",
        "autoprefixer": "^10.4.27",
        "jsdom": "^26.1.0",
        "msw": "^2.10.3",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.2",
        "typescript": "~5.9.3",
        "vite": "8.0.1",
        "vite-plus": "0.1.12",
        "vitest": "^3.2.4"
    },
    "volta": {
        "node": "24.2.0"
    },
    "packageManager": "pnpm@10.32.1",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@rustzen/zipper",
            "@swc/core",
            "@tailwindcss/oxide",
            "esbuild"
        ]
    }
}
