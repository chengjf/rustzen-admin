# PostgreSQL Database URL
# Example: "postgresql://username:password@host:port/database"
RUSTZEN_DB_URL="postgresql://your_username:your_password@localhost:5432/rustzen_admin"

# for sqlx-cli
DATABASE_URL="postgresql://your_username:your_password@localhost:5432/rustzen_admin"

# Server configuration
RUSTZEN_APP_HOST="0.0.0.0"
RUSTZEN_APP_PORT="8007"

# Session expiration in seconds (default: 28800 = 8 hours)
RUSTZEN_SESSION_EXPIRATION_SECS=28800

# Database connection pool
RUSTZEN_DB_MAX_CONN=10
RUSTZEN_DB_MIN_CONN=1
RUSTZEN_DB_CONN_TIMEOUT=10   # seconds before a connection attempt times out
RUSTZEN_DB_IDLE_TIMEOUT=0    # seconds before idle connection is dropped (0 = disabled)

# Logging — controls tracing output verbosity (uses standard RUST_LOG env var)
# Examples: info | debug | warn | rustzen_admin=debug,sqlx=warn
RUST_LOG=info

# Development notes:
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to version control
# 3. Use environment-specific values for production
